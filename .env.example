# Kopieer dit bestand naar .env.local en vul de waarden in.

# --- Supabase (server-only, NOOIT in de client) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (nodig vanaf stap 3, AI-chat) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# --- Telegram (leadmeldingen + operator-alert) ---
# Bot-token via @BotFather. OPERATOR_TELEGRAM_CHAT_ID is jouw eigen chat_id;
# in de demo is dat ook het notify_target van demo-hovenier.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
OPERATOR_TELEGRAM_CHAT_ID=123456789

# --- Later: telefonie / SMS / WhatsApp (nu niet nodig, notifier-stubs staan klaar) ---
# BIRD_API_KEY=
# BIRD_WORKSPACE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
