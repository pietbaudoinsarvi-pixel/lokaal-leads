# Kopieer dit bestand naar .env.local en vul de waarden in.

# --- Supabase (server-only, NOOIT in de client) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (nodig vanaf stap 3, AI-chat) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# --- Meldkanaal ---
# "whatsapp" of "telegram" (default). Bepaalt waar de demo-configs hun
# meldingen naartoe sturen; zie SETUP-WHATSAPP.md voor de omschakeling.
NOTIFY_CHANNEL=telegram

# --- Telegram (fallback-kanaal + operator-alert) ---
# Bot-token via @BotFather. OPERATOR_TELEGRAM_CHAT_ID is jouw eigen chat_id.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
OPERATOR_TELEGRAM_CHAT_ID=123456789

# --- WhatsApp (zie SETUP-WHATSAPP.md) ---
# Jouw eigen nummer voor operator-meldingen:
# OPERATOR_WHATSAPP_NUMBER=+31612345678
# Route A (quick-start, alleen meldingen aan jezelf):
# CALLMEBOT_API_KEY=
# Route B (productie, Meta Cloud API):
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_TEMPLATE_NAME=melding_operator
# WHATSAPP_REVIEW_TEMPLATE_NAME=review_verzoek
# WHATSAPP_TEMPLATE_LANGUAGE=nl
# Providerkeuze forceren (anders automatisch): WHATSAPP_PROVIDER=cloud|callmebot

# --- Later: telefonie / SMS (stubs staan klaar) ---
# BIRD_API_KEY=
# BIRD_WORKSPACE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
